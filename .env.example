# ── Database (required for saved/shared edits) ───────────────────────────────
# A Postgres connection string. Free option: https://neon.tech  (copy the
# "pooled" connection string it gives you, including ?sslmode=require).
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# ── Meta / Facebook Ads (optional — cards work without it, numbers just stay
#    on whatever was last entered manually until you add these) ───────────────
# A long-lived access token with ads_read permission.
# Get one at https://developers.facebook.com (Graph API Explorer / System User).
META_ACCESS_TOKEN=
# Date window the dashboard pulls. Options: today, yesterday, last_7d, last_30d, this_month
META_DATE_PRESET=last_7d
# Which "action type" counts as a conversion for CPA/CPL.
# Common values: lead, offsite_conversion.fb_pixel_lead, purchase, complete_registration
META_CONVERSION_ACTION=lead

# ── ClickUp (optional — adds account context to each card) ───────────────────
# Personal API token from ClickUp → Settings → Apps.
CLICKUP_API_TOKEN=

# ── Access control ───────────────────────────────────────────────────────────
# Anyone with the link can VIEW. To make EDITING require a shared password,
# set this. Leave blank to let anyone with the link edit (true "public" mode).
EDIT_PASSWORD=
